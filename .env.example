# Janitor Bot Configuration
# Copy to .env and adjust values as needed.

# HTTP server port (default: 3000)
PORT=3000

# SQLite database path (default: /data/janitor-throws.db in Docker)
# DB_PATH=/data/janitor-throws.db

# Slack incoming webhook URL for notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Polling interval in minutes (default: 30)
# POLL_INTERVAL_MINUTES=30

# Minimum play tier to report: high, medium, low (optional, default: all)
# MIN_TIER=high

# Logging verbosity: debug, info, warn, error (default: info)
# LOG_LEVEL=info
